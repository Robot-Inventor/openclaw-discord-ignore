{
    "id": "discord-ignore",
    "name": "Discord Ignore",
    "description": "Rule-based Discord message filtering and /cooldown slash command support for OpenClaw.",
    "activation": {
        "onStartup": true
    },
    "configSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "autoCooldown": {
                "default": false,
                "oneOf": [
                    {
                        "type": "boolean"
                    },
                    {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                            "cooldownMinutes": {
                                "type": "number",
                                "default": 10,
                                "exclusiveMinimum": 0
                            },
                            "requestCount": {
                                "type": "number",
                                "default": 10,
                                "exclusiveMinimum": 0
                            },
                            "withinMinutes": {
                                "type": "number",
                                "default": 10,
                                "exclusiveMinimum": 0
                            }
                        }
                    }
                ]
            },
            "defaultCooldownMinutes": {
                "type": "number",
                "default": 30,
                "exclusiveMinimum": 0
            },
            "ignoredAccountIds": {
                "type": "array",
                "default": [],
                "items": {
                    "type": "string"
                }
            },
            "ignoredLeadingStrings": {
                "type": "array",
                "default": [],
                "items": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    },
    "uiHints": {
        "autoCooldown": {
            "label": "Automatic cooldown",
            "help": "Automatically enables cooldown when too many messages arrive within the configured time window. Use true for defaults, false to disable, or an object to customize it."
        },
        "defaultCooldownMinutes": {
            "label": "Default cooldown minutes",
            "help": "Default cooldown duration used by /cooldown and /cooldown on."
        },
        "ignoredAccountIds": {
            "label": "Ignored account IDs",
            "help": "Discord account IDs whose inbound messages should be ignored before agent dispatch."
        },
        "ignoredLeadingStrings": {
            "label": "Ignored leading strings",
            "help": "Message prefixes that should be ignored after Discord mentions are stripped."
        }
    }
}
