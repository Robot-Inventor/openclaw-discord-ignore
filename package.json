{
  "name": "@robot-inventor/discord-ignore",
  "version": "1.1.7",
  "description": "Rule-based Discord message filtering and /cooldown slash command support for OpenClaw.",
  "keywords": [
    "openclaw",
    "discord",
    "plugin",
    "openclaw-plugin",
    "agent"
  ],
  "homepage": "https://github.com/Robot-Inventor/openclaw-discord-ignore#readme",
  "bugs": {
    "url": "https://github.com/Robot-Inventor/openclaw-discord-ignore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Robot-Inventor/openclaw-discord-ignore.git"
  },
  "license": "MIT",
  "author": "Robot-Inventor",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "./dist",
    "./openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "lint": "eslint --flag unstable_native_nodejs_ts_config \"./src/**/*.ts\"",
    "ci:version": "changeset version",
    "ci:publish": "npm run build && changeset publish && clawhub package publish ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@robot-inventor/eslint-config": "^13.0.0",
    "@robot-inventor/tsconfig-base": "^7.1.0",
    "@types/bun": "^1.3.14",
    "clawhub": "^0.23.1",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "openclaw": "^2026.6.11",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "zod-validation-error": "^5.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.2",
      "minGatewayVersion": ">=2026.5.2"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  }
}
